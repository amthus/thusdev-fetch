{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ESNext",

    "declaration": true,
    "sourceMap": true,
    "declarationMap": true,

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "isolatedModules": true,
    "moduleDetection": "force",
    "skipLibCheck": true,

    "types": ["node"]
  },
  "include": ["src"],
  "exclude": ["test", "dist", "node_modules"]
}